[
  {
    "id": "q-overseas-expansion",
    "step": 1,
    "title": "Are you planning overseas expansion?",
    "type": "radio",
    "fieldName": "dynamicAnswers.planningOverseas",
    "options": [
      "Yes",
      "No"
    ],
    "required": true,
    "followUpQuestions": [
      {
        "id": "q-target-market",
        "step": 2,
        "title": "Which markets are you targeting?",
        "type": "text",
        "fieldName": "dynamicAnswers.targetMarket",
        "required": true,
        "conditions": [
          {
            "field": "dynamicAnswers.planningOverseas",
            "operator": "equals",
            "value": "Yes"
          }
        ],
        "followUpQuestions": [
          {
            "id": "q-new-market",
            "step": 3,
            "title": "Is this a new market for your company?",
            "type": "radio",
            "fieldName": "dynamicAnswers.newMarket",
            "options": [
              "Yes",
              "No"
            ],
            "required": true
          },
          {
            "id": "q-overseas-sales",
            "step": 3,
            "title": "What are your current overseas sales in this market?",
            "type": "number",
            "fieldName": "dynamicAnswers.overseasSales",
            "required": true
          },
          {
            "id": "q-mra-activity",
            "step": 4,
            "title": "What type of overseas activity are you planning?",
            "type": "radio",
            "fieldName": "dynamicAnswers.mraActivityType",
            "options": [
              "Promotion",
              "Business Development",
              "Market Setup",
              "Other"
            ],
            "required": true
          },
          {
            "id": "q-activity-count",
            "step": 4,
            "title": "How many activities per application?",
            "type": "number",
            "fieldName": "dynamicAnswers.activityCount",
            "required": true
          }
        ]
      }
    ],
    "metadata": {
      "status": "FUTURE"
    }
  },
  {
