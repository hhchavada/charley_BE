        "options": [
          "Yes",
          "No",
          "Not Sure"
        ],
        "required": true,
        "conditions": [
          {
            "field": "dynamicAnswers.planningIT",
            "operator": "equals",
            "value": "Yes"
          }
        ]
      },
      {
        "id": "q-already-purchased",
        "step": 2,
