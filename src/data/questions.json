        ],
        "required": true,
        "conditions": [
          {
            "field": "dynamicAnswers.planningIT",
            "operator": "equals",
            "value": "Yes"
          }
        ]
      }
    ],
    "metadata": {
      "status": "FUTURE"
    }
  },
