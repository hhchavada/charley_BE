[
  {
    "id": "edg-marketing",
    "name": "Enterprise Development Grant (EDG) - Brand & Marketing",
    "priority": 1,
    "mergeGroup": "EDG",
    "streamPriority": 1,
    "estimatedFunding": "Up to $30,000",
    "typicalFunding": ",000 - ,000 (Ceiling )",
    "officialCap": "$50,000",
    "supportPercentage": "50%",
    "windowStatus": "OPEN",
    "description": "Support for companies to develop their brand and marketing strategy.",
    "tags": [
      "Marketing",
      "Brand",
      "Strategy"
    ],
    "conditions": [
      {
        "condition": "OR",
        "rules": [
          {
            "field": "initialData.purpose",
            "operator": "contains",
            "value": "Business Growth"
          },
          {
            "field": "initialData.purpose",
            "operator": "contains",
            "value": "Entering New Markets"
          },
          {
            "field": "dynamicAnswers.projectType",
            "operator": "equals",
            "value": "Brand & Marketing"
          },
          {
            "field": "dynamicAnswers.planningMarketing",
            "operator": "equals",
            "value": "Yes"
          }
        ]
      },
      {
        "field": "dynamicAnswers.localShareholding",
        "operator": ">=",
        "value": 30
      },
      {
        "field": "dynamicAnswers.financiallyViable",
        "operator": "equals",
        "value": "Yes"
      },
      {
        "field": "dynamicAnswers.currentRatio",
        "operator": ">",
        "value": 1
      },
      {
        "field": "dynamicAnswers.retainedEarnings",
        "operator": ">",
        "value": 50000
      },
      {
        "field": "dynamicAnswers.canAffordProject",
        "operator": "equals",
        "value": "Yes"
      },
      {
        "field": "dynamicAnswers.investorCapital",
        "operator": "exists",
        "value": ""
      },
      {
        "field": "dynamicAnswers.projectStarted",
        "operator": "equals",
        "value": "No"
      },
      {
        "field": "dynamicAnswers.useSacConsultant",
        "operator": "equals",
        "value": "Yes"
      },
      {
        "field": "dynamicAnswers.vendorRelatedParty",
        "operator": "equals",
        "value": "No"
      },
      {
        "field": "dynamicAnswers.marketingType",
        "operator": "not_in",
        "value": [
          "Websites",
          "SEO",
          "Advertising"
        ]
      }
    ],
    "metadata": {
      "consultantRequired": true,
      "requiresProjectNotStarted": true,
      "warnings": [
        "Websites / SEO / Advertising should recommend PSG instead."
      ]
    },
    "maximumFunding": ",000",
    "processingTime": "8-12 weeks",
    "claimTime": "8-12 weeks",
    "payoutTime": "1-4 weeks",
    "grantCategory": "Business Growth"
  },
